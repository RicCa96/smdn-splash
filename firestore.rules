rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Squadre e partite: lettura pubblica, scrittura solo admin autenticato
    match /teams/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /matches/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Voti MVP: lettura pubblica, chiunque può creare un voto (validato),
    // solo l'admin può modificare/eliminare
    match /votes/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['player', 'teamName', 'tournament', 'ts'])
        && request.resource.data.player is string
        && request.resource.data.player.size() > 0
        && request.resource.data.player.size() < 80
        && request.resource.data.teamName is string
        && request.resource.data.teamName.size() < 80
        && request.resource.data.tournament in ['calcetto', 'volley'];
      allow update, delete: if request.auth != null;
    }
  }
}
